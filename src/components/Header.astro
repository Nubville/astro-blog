---
const navItems = [
  { href: '/', label: 'Home', icon: '⚓' },
  { href: '/blog/', label: 'Quest Log', icon: '📜' },
  { href: '/tags/', label: 'Topics', icon: '🗺' },
  { href: '/about/', label: 'About', icon: '⚔' },
  { href: '/tokens/', label: 'Design Tokens', icon: '🎨' },
];

const { pathname } = Astro.url;

function isActive(href: string) {
  return href === '/' ? pathname === '/' : pathname.startsWith(href);
}
---

<header>
  <a href="/" class="brand" aria-label="Andrew Garman — home">Andrew Garman</a>
  <span class="brand-sub" aria-hidden="true">// dev + design</span>

  <nav class="header-nav" aria-label="Main navigation">
    <ul class="nav-list" role="list">
      {
        navItems.map(({ href, label, icon }) => (
          <li class="nav-item">
            <a
              href={href}
              class={`nav-link${isActive(href) ? ' nav-link--active' : ''}`}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              <span class="nav-icon" aria-hidden="true">
                {icon}
              </span>
              <span class="nav-label">{label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <button
    class="nav-toggle"
    aria-label="Open navigation menu"
    aria-expanded="false"
    aria-controls="mobile-nav-dialog"
  >
    <span class="bar" aria-hidden="true"></span>
    <span class="bar" aria-hidden="true"></span>
    <span class="bar" aria-hidden="true"></span>
  </button>
</header>

<dialog id="mobile-nav-dialog" aria-label="Navigation menu">
  <div class="dialog-inner">
    <button class="dialog-close" aria-label="Close navigation menu" autofocus>✕</button>
    <nav aria-label="Mobile navigation">
      <ul class="dialog-nav-list" role="list">
        {
          navItems.map(({ href, label, icon }) => (
            <li>
              <a
                href={href}
                class={`dialog-nav-link${isActive(href) ? ' dialog-nav-link--active' : ''}`}
                aria-current={isActive(href) ? 'page' : undefined}
              >
                <span aria-hidden="true">{icon}</span>
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</dialog>

<script>
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const dialog = document.querySelector('#mobile-nav-dialog') as HTMLDialogElement;
  const closeBtn = dialog.querySelector('.dialog-close') as HTMLButtonElement;

  toggle.addEventListener('click', () => {
    dialog.showModal();
    toggle.setAttribute('aria-expanded', 'true');
  });

  closeBtn.addEventListener('click', () => dialog.close());

  // Backdrop click closes
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });

  // Restore focus to toggle and reset aria-expanded on any close (Escape or button)
  dialog.addEventListener('close', () => {
    toggle.setAttribute('aria-expanded', 'false');
    toggle.focus();
  });
</script>

<style>
  header {
    align-items: center;
    border-bottom: 1px solid var(--pencil);
    display: flex;
    gap: var(--ag-space-m);
    padding: var(--ag-space-s) var(--ag-space-2xl);
  }

  .brand {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: var(--font-size-3);
    font-weight: var(--font-weight-regular);
    letter-spacing: 0.05em;
    text-decoration: none;
    white-space: nowrap;

    &:hover {
      color: var(--brand-1);
    }

    &:focus-visible {
      border-radius: 2px;
      outline: 2px solid var(--brand-1);
      outline-offset: 4px;
    }
  }

  .brand-sub {
    color: var(--ink-faint);
    font-family: var(--font-mono);
    font-size: var(--ag-font-size-xs);
    letter-spacing: 0.04em;
  }

  /* ── Desktop nav ─────────────────────────────────── */
  .header-nav {
    margin-left: auto;
  }

  .nav-list {
    display: flex;
    flex-direction: row;
    gap: var(--ag-space-2xs);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    list-style: none;
  }

  .nav-link {
    align-items: center;
    border: 1px solid var(--pencil);
    border-radius: 2px;
    color: var(--ink-faint);
    display: flex;
    font-family: var(--font-mono);
    font-size: var(--ag-font-size-xs);
    gap: var(--ag-space-2xs);
    letter-spacing: 0.06em;
    padding: var(--ag-space-2xs) var(--ag-space-s);
    text-decoration: none;
    text-transform: uppercase;
    transition:
      border-color var(--ag-transition-fast),
      color var(--ag-transition-fast),
      background var(--ag-transition-fast);

    &:hover {
      background: var(--paper-dark);
      border-color: var(--ink);
      color: var(--ink);
    }

    &:focus-visible {
      outline: 2px solid var(--brand-1);
      outline-offset: 2px;
    }
  }

  .nav-link--active {
    border-color: var(--brand-1);
    color: var(--brand-1);
  }

  .nav-icon {
    font-size: 0.85em;
    line-height: 1;
  }

  /* ── Hamburger button ────────────────────────────── */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    margin-left: auto;
    width: 2.5rem;
    height: 2.5rem;
    background: none;
    border: 1px solid var(--pencil);
    border-radius: 2px;
    cursor: pointer;
    padding: var(--ag-space-xs);

    &:hover {
      background: var(--paper-dark);
      border-color: var(--ink);

      & .bar {
        background: var(--ink);
      }
    }

    &:focus-visible {
      outline: 2px solid var(--brand-1);
      outline-offset: 2px;
    }
  }

  .bar {
    display: block;
    width: 1.1rem;
    height: 1.5px;
    background: var(--ink-faint);
    border-radius: 1px;
    transition: background var(--ag-transition-fast);
  }

  /* ── Mobile breakpoint ───────────────────────────── */
  @media (max-width: 999px) {
    .brand-sub {
      display: none;
    }

    .header-nav {
      display: none;
    }

    .nav-toggle {
      display: flex;
    }
  }

  /* ── Dialog ──────────────────────────────────────── */
  #mobile-nav-dialog {
    background: var(--paper);
    border: 1px solid var(--pencil);
    border-radius: 2px;
    box-shadow: 4px 4px 0 var(--ink);
    margin: auto;
    max-width: min(340px, 90vw);
    padding: 0;
    width: 100%;

    &::backdrop {
      background: rgba(42, 30, 16, 0.45);
    }
  }

  .dialog-inner {
    align-items: center;
    display: flex;
    flex-direction: column;
    gap: var(--ag-space-m);
    padding: var(--ag-space-l) var(--ag-space-xl);
  }

  .dialog-close {
    align-self: flex-end;
    background: none;
    border: 1px solid var(--pencil);
    border-radius: 2px;
    color: var(--ink-faint);
    cursor: pointer;
    font-size: var(--ag-font-size-s);
    line-height: 1;
    padding: var(--ag-space-2xs) var(--ag-space-xs);

    &:hover {
      border-color: var(--ink);
      color: var(--ink);
    }

    &:focus-visible {
      outline: 2px solid var(--brand-1);
      outline-offset: 2px;
    }
  }

  .dialog-nav-list {
    align-items: stretch;
    display: flex;
    flex-direction: column;
    gap: var(--ag-space-xs);
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
  }

  .dialog-nav-link {
    align-items: center;
    border: 1px solid var(--pencil);
    border-radius: 2px;
    color: var(--ink-faint);
    display: flex;
    font-family: var(--font-mono);
    font-size: var(--ag-font-size-s);
    gap: var(--ag-space-xs);
    justify-content: center;
    letter-spacing: 0.06em;
    padding: var(--ag-space-s) var(--ag-space-l);
    text-decoration: none;
    text-transform: uppercase;
    transition:
      border-color var(--ag-transition-fast),
      color var(--ag-transition-fast),
      background var(--ag-transition-fast);

    &:hover {
      background: var(--paper-dark);
      border-color: var(--ink);
      color: var(--ink);
    }

    &:focus-visible {
      outline: 2px solid var(--brand-1);
      outline-offset: 2px;
    }
  }

  .dialog-nav-link--active {
    border-color: var(--brand-1);
    color: var(--brand-1);
  }
</style>
