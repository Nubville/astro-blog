---
interface Props {
  nameHeading?: 'h1' | 'h2';
}
const { nameHeading: NameTag = 'h1' } = Astro.props;
---

<section class="hero" aria-label="Site introduction">
  <sketch-card type="character" class="profile-card">
    <div class="card-content profile-content">
      <p class="profile-annotation">// profile card · v0.1</p>

      <div class="profile-body">
        <div class="portrait">
          <img
            src="/images/drew_avatar.jpg"
            alt="Andrew Garman — a generated illustration of the author as a css wizard with a mix of coding and dungeon master dice"
            width="240"
            height="320"
            loading="eager"
          />
        </div>

        <div class="profile-info">
          <NameTag class="profile-name">Andrew Garman</NameTag>
          <p class="profile-role">Senior Front-End Developer</p>

          <ul class="profile-tags" role="list" aria-label="Interests">
            <li class="tag tag--code">⌨ Code</li>
            <li class="tag tag--dnd">⚔ D&amp;D</li>
            <li class="tag tag--make">🖨 3D Print</li>
            <li class="tag tag--fish">🎣 Fishing</li>
            <li class="tag tag--kayak">🤖 IoT</li>
          </ul>
        </div>
      </div>
    </div>
  </sketch-card>
</section>

<style>
  .hero {
    margin-bottom: var(--ag-space-2xl);
  }

  /* No max-width here — the grid column constrains the card width */
  .profile-card {
    width: 100%;
  }

  .profile-content {
    padding: var(--ag-space-l) var(--ag-space-xl) var(--ag-space-xl);
  }

  .profile-annotation {
    border-bottom: solid var(--ag-border-width-m) var(--pencil);
    color: var(--ink-faint);
    font-family: var(--font-mono);
    font-size: var(--ag-font-size-xs);
    letter-spacing: 0.05em;
    padding-bottom: var(--ag-space-m);
    margin: 0 0 var(--ag-space-l);
  }

  /* Default: stacked — portrait above text */
  .profile-body {
    align-items: flex-start;
    display: flex;
    flex-direction: column;
    gap: var(--ag-space-m);
  }

  .portrait {
    flex-shrink: 0;
    width: 80px;
  }

  .portrait img {
    display: block;
    height: auto;
    mix-blend-mode: multiply;
    width: 100%;
  }

  .profile-info {
    flex: 1;
    min-width: 0;
  }

  .profile-name {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: var(--ag-font-size-xl);
    font-weight: var(--font-weight-regular);
    letter-spacing: 0.04em;
    margin: 0 0 var(--ag-space-2xs);
  }

  .profile-role {
    color: var(--brand-1);
    font-family: var(--font-mono);
    font-size: var(--ag-font-size-xs);
    letter-spacing: 0.1em;
    margin: 0 0 var(--ag-space-m);
    text-transform: uppercase;
  }

  .profile-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ag-space-2xs);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tag {
    border: 1px solid var(--pencil);
    border-radius: 2px;
    color: var(--ink-faint);
    font-family: var(--font-mono);
    font-size: var(--ag-font-size-xs);
    letter-spacing: 0.06em;
    padding: var(--ag-space-2xs) var(--ag-space-xs);
    text-transform: uppercase;
  }

  .tag--code {
    border-color: var(--blue-ink);
    color: var(--blue-ink);
  }
  .tag--dnd {
    border-color: var(--brand-1);
    color: var(--brand-1);
  }
  .tag--make {
    border-color: var(--amber-ink);
    color: var(--amber-ink);
  }
  .tag--fish,
  .tag--kayak {
    border-color: var(--green-ink);
    color: var(--green-ink);
  }

  /* Step 3: Container queries — card responds to its own width */

  /* Medium (420px+): portrait left, info right */
  @container sketch-card (min-width: 420px) {
    .profile-body {
      flex-direction: row;
      gap: var(--ag-space-l);
    }

    .portrait {
      width: 100px;
    }
  }

  /* Wide (640px+): larger portrait, bigger name, unwrap tags */
  @container sketch-card (min-width: 640px) {
    .profile-body {
      gap: var(--ag-space-xl);
    }

    .portrait {
      width: 140px;
    }

    .profile-name {
      font-size: var(--ag-font-size-2xl);
    }

    .profile-tags {
      flex-wrap: nowrap;
    }
  }

  /* Hero (900px+): portrait tall left column, rich info right */
  @container sketch-card (min-width: 900px) {
    .profile-content {
      align-items: start;
      display: grid;
      gap: var(--ag-space-3xl);
      grid-template-columns: 240px 1fr;
    }

    .profile-annotation {
      grid-column: 1 / -1;
      margin-bottom: 0;
    }

    .profile-body {
      flex-direction: column;
      gap: var(--ag-space-l);
      grid-column: 2;
      grid-row: 2;
    }

    .portrait {
      grid-column: 1;
      grid-row: 2;
      width: 100%;
    }
  }
</style>
