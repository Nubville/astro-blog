---

---

<section class="hero" aria-label="Site introduction">
  <sketch-card type="character" class="profile-card">
    <div class="card-content profile-content">
      <p class="profile-annotation">// profile card · v0.1</p>

      <div class="profile-body">
        <div class="portrait">
          <img
            src="/images/sketched_me.png"
            alt="Andrew Garman — pencil sketch portrait"
            width="240"
            height="320"
            loading="eager"
          />
        </div>

        <div class="profile-info">
          <h1 class="profile-name">Andrew Garman</h1>
          <p class="profile-role">Senior Front-End Developer</p>

          <ul class="profile-tags" role="list" aria-label="Interests">
            <li class="tag tag--code">⌨ Code</li>
            <li class="tag tag--dnd">⚔ D&amp;D</li>
            <li class="tag tag--make">🖨 3D Print</li>
            <li class="tag tag--fish">🎣 Fishing</li>
            <li class="tag tag--kayak">🚣 Kayak</li>
          </ul>
        </div>
      </div>
    </div>
  </sketch-card>
</section>

<style>
  .hero {
    padding: 2.5rem 2.5rem 1.5rem;
  }

  /* No max-width here — the grid column constrains the card width */
  .profile-card {
    width: 100%;
  }

  .profile-content {
    padding: 1.5rem 1.75rem 2rem;
  }

  .profile-annotation {
    color: var(--pencil);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    margin: 0 0 1.25rem;
  }

  /* Default: stacked — portrait above text */
  .profile-body {
    align-items: flex-start;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .portrait {
    flex-shrink: 0;
    width: 80px;
  }

  .portrait img {
    display: block;
    height: auto;
    mix-blend-mode: multiply;
    width: 100%;
  }

  .profile-info {
    flex: 1;
    min-width: 0;
  }

  .profile-name {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: var(--font-weight-regular);
    letter-spacing: 0.04em;
    margin: 0 0 0.2rem;
  }

  .profile-role {
    color: var(--brand-1);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    margin: 0 0 1.1rem;
    text-transform: uppercase;
  }

  .profile-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tag {
    border: 1px solid var(--pencil);
    border-radius: 2px;
    color: var(--ink-faint);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.5rem;
    text-transform: uppercase;
  }

  .tag--code {
    border-color: var(--blue-ink);
    color: var(--blue-ink);
  }
  .tag--dnd {
    border-color: var(--brand-1);
    color: var(--brand-1);
  }
  .tag--make {
    border-color: var(--amber-ink);
    color: var(--amber-ink);
  }
  .tag--fish,
  .tag--kayak {
    border-color: var(--green-ink);
    color: var(--green-ink);
  }

  /* Step 3: Container queries — card responds to its own width */

  /* Medium (420px+): portrait left, info right */
  @container sketch-card (min-width: 420px) {
    .profile-body {
      flex-direction: row;
      gap: 1.5rem;
    }

    .portrait {
      width: 100px;
    }
  }

  /* Wide (640px+): larger portrait, bigger name, unwrap tags */
  @container sketch-card (min-width: 640px) {
    .profile-body {
      gap: 2rem;
    }

    .portrait {
      width: 140px;
    }

    .profile-name {
      font-size: 2.25rem;
    }

    .profile-tags {
      flex-wrap: nowrap;
    }
  }

  /* Hero (900px+): portrait tall left column, rich info right */
  @container sketch-card (min-width: 900px) {
    .profile-content {
      align-items: start;
      display: grid;
      gap: 3rem;
      grid-template-columns: 240px 1fr;
    }

    .profile-annotation {
      grid-column: 1 / -1;
      margin-bottom: 0;
    }

    .profile-body {
      flex-direction: column;
      gap: 1.5rem;
      grid-column: 2;
      grid-row: 2;
    }

    .portrait {
      grid-column: 1;
      grid-row: 2;
      width: 100%;
    }
  }
</style>
