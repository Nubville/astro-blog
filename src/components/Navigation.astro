<!-- Purely decorative binding strip — nav links live in Header -->
<div class="binding-strip" aria-hidden="true"></div>

<style>
  .binding-strip {
    /* Two stacked radial gradients per repeat cell:
       1. Inner shadow offset toward top-left
       2. The hole: paper fill + ink border ring for clear visibility  */
    background-image:
      radial-gradient(circle, rgba(0, 0, 0, 0.18) 3px, transparent 3px),
      radial-gradient(
        circle,
        var(--paper) 0px,
        var(--paper) 4px,
        var(--ink) 4px,
        var(--ink) 5.5px,
        transparent 5.5px
      );
    /* 52px repeat ≈ twice the original hole-to-hole spacing */
    background-size: 100% 52px;
    background-position: center 24px;
    background-repeat: repeat-y;
    /* stretch to full grid-row height without needing explicit height */
    align-self: stretch;
    width: 100%;
  }
</style>
