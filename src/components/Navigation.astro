---
const navItems = [
  { href: '/', label: 'Home', icon: '⚓' },
  { href: '/blog/', label: 'Quest Log', icon: '📜' },
  { href: '/tags/', label: 'Topics', icon: '🗺' },
  { href: '/about/', label: 'About', icon: '⚔' },
];
---

<nav class="margin-nav" aria-label="Main navigation">
  <!-- Binding holes — decorative -->
  <div class="binding-holes" aria-hidden="true">
    {Array.from({ length: 9 }).map(() => <span class="hole" />)}
  </div>

  <ul role="list">
    {
      navItems.map(({ href, label, icon }) => (
        <li>
          <a href={href} aria-label={label} title={label}>
            <span aria-hidden="true">{icon}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .margin-nav {
    align-items: center;
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    padding: 0;
    position: sticky;
    top: 0;
    width: 100%;
  }

  .binding-holes {
    align-items: center;
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding: 16px 0 12px;
    width: 100%;
  }

  .hole {
    background: var(--paper-dark);
    border: 1px solid var(--pencil);
    border-radius: 50%;
    box-shadow:
      inset 0 1px 3px rgba(0, 0, 0, 0.18),
      0 0 0 1px rgba(0, 0, 0, 0.06);
    display: block;
    flex-shrink: 0;
    height: 10px;
    width: 10px;
  }

  ul {
    align-items: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 8px 0;
    width: 100%;
  }

  a {
    align-items: center;
    border-radius: 3px;
    color: var(--ink-faint);
    display: flex;
    font-size: 1rem;
    height: 32px;
    justify-content: center;
    text-decoration: none;
    width: 32px;

    &:hover {
      background: var(--paper-dark);
      color: var(--ink);
    }

    &:focus-visible {
      outline: 2px solid var(--brand-1);
      outline-offset: 2px;
    }
  }
</style>
