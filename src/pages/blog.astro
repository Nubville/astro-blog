---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

type CardType = 'quest' | 'spellbook' | 'lore' | 'character';

interface MarkdownPost {
  url: string;
  frontmatter: {
    title: string;
    pubDate: string;
    description?: string;
    type?: CardType;
    tags?: string[];
  };
}

const allPosts = Object.values(
  import.meta.glob<MarkdownPost>('./posts/*.md', { eager: true })
).sort(
  (a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime()
);

const pageTitle = 'Quest Log';

function deriveType(post: MarkdownPost): CardType {
  if (post.frontmatter.type) return post.frontmatter.type;
  const tags = post.frontmatter.tags ?? [];
  if (tags.some((t) => ['dnd', 'd&d', 'gaming', 'character'].includes(t))) return 'character';
  if (tags.some((t) => ['outdoors', 'fishing', 'kayak', '3dprint'].includes(t))) return 'lore';
  if (tags.some((t) => ['learning in public', 'learning', 'community', 'blogging'].includes(t)))
    return 'spellbook';
  return 'quest';
}
---

<BaseLayout pageTitle={pageTitle}>
  <section class="posts-grid" aria-label="Blog posts">
    {
      allPosts.map((post) => (
        <PostCard
          type={deriveType(post)}
          url={post.url}
          title={post.frontmatter.title}
          description={post.frontmatter.description}
          pubDate={post.frontmatter.pubDate}
        />
      ))
    }
  </section>
</BaseLayout>

<style>
  .posts-grid {
    padding-bottom: 2rem;
  }
</style>
