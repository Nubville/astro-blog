---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CharacterSheet from '../components/CharacterSheet.astro';
import CharacterTraits from '../components/CharacterTraits.astro';

type CardType = 'quest' | 'spellbook' | 'lore' | 'character';

interface MarkdownPost {
  url: string;
  frontmatter: {
    title: string;
    pubDate: string;
    description?: string;
    type?: CardType;
    tags?: string[];
  };
}

const sortedPosts = Object.values(
  import.meta.glob<MarkdownPost>('./posts/*.md', { eager: true })
).sort(
  (a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime()
);

const allPosts = sortedPosts.slice(0, 6);

function deriveType(post: MarkdownPost): CardType {
  if (post.frontmatter.type) return post.frontmatter.type;
  const tags = post.frontmatter.tags ?? [];
  if (tags.some((t) => ['dnd', 'd&d', 'gaming', 'character'].includes(t))) return 'character';
  if (tags.some((t) => ['outdoors', 'fishing', 'kayak', '3dprint'].includes(t))) return 'lore';
  if (tags.some((t) => ['learning in public', 'learning', 'community', 'blogging'].includes(t)))
    return 'spellbook';
  return 'quest';
}

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout pageTitle="Andrew Garman — Dev Blog" showPageTitle={false}>
  <section class="hero-section" aria-label="Profile">
    <Hero />
    <CharacterSheet />
  </section>

  <section class="latest" aria-labelledby="latest-heading">
    <h2 id="latest-heading" class="section-heading">Latest Posts</h2>
    <div class="posts-grid">
      {
        allPosts.map((post) => {
          const type = deriveType(post);
          return (
            <sketch-card type={type}>
              <div class="card-content">
                <span class="card-type-label">[ {type} ]</span>
                <h3 class="card-post-title">
                  <a class="card-title" href={post.url}>
                    {post.frontmatter.title}
                  </a>
                </h3>
                {post.frontmatter.description && (
                  <p class="card-excerpt">{post.frontmatter.description}</p>
                )}
                <time class="card-date" datetime={post.frontmatter.pubDate}>
                  {formatDate(post.frontmatter.pubDate)}
                </time>
              </div>
            </sketch-card>
          );
        })
      }
    </div>
  </section>

  <div class="traits-col">
    <CharacterTraits />
  </div>
</BaseLayout>

<style>
  .hero-section {
    max-inline-size: 480px;
  }

  @container content-col (min-width: 960px) {
    .hero-section {
      max-inline-size: none;
    }
  }

  /* .latest is its own container so posts-grid responds to its actual width,
     not main-canvas (which fires at the full main width in the 3-col layout) */
  .latest {
    container-type: inline-size;
    container-name: latest-col;
  }

  /* Reset global main-canvas posts-grid rules — Astro scoped specificity wins */
  .posts-grid {
    grid-template-columns: 1fr;
  }

  @container latest-col (min-width: 560px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @container latest-col (min-width: 900px) {
    .posts-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .section-heading {
    margin-bottom: 1rem;
  }

  .card-post-title {
    font-size: var(--ag-font-size-m);
    margin: 0 0 0.5rem;
  }
</style>
