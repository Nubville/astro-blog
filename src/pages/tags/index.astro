---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface MarkdownPost {
  frontmatter: { tags: string[] };
}

const allPosts = Object.values(import.meta.glob<MarkdownPost>('../posts/*.md', { eager: true }));
const allTags = allPosts.map((post) => post.frontmatter.tags).flat();
const tags = [...new Set(allTags)]
  .map((tag) => ({ tag, count: allTags.filter((t) => t === tag).length }))
  .sort((a, b) => a.tag.localeCompare(b.tag));
const pageTitle = 'Tag Index';
---

<BaseLayout pageTitle={pageTitle}>
  <div class="tags">
    {
      tags.map(({ tag, count }) => (
        <p class="tag">
          <a href={`/tags/${tag}`}>
            {tag} <span class="tag-count">×{count}</span>
          </a>
        </p>
      ))
    }
  </div>
</BaseLayout>

<style>
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    margin: 0;
    border: dotted 1px var(--pencil);
    border-radius: 0.5em;
    padding: 0.4em 1em;
    font-size: var(--ag-font-size-s);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }

  .tag a {
    color: var(--ink-faint);
    text-decoration: none;

    &:hover {
      color: var(--brand-1);
    }
  }

  .tag-count {
    color: var(--ink-faint);
    font-size: var(--ag-font-size-3xs);
  }
</style>
